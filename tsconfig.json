import express from 'express';
import { Telegraf } from 'telegraf';
import { GoogleGenerativeAI } from '@google/generative-ai';
import path from 'path';
import fs from 'fs';
import dotenv from 'dotenv';

dotenv.config();

// Configuration
const TOKEN = process.env.TELEGRAM_BOT_TOKEN;
const GEMINI_API_KEY = process.env.GEMINI_API_KEY;
const PORT = 3000;

if (!TOKEN) {
  console.error('TELEGRAM_BOT_TOKEN is missing in .env');
}

if (!GEMINI_API_KEY) {
  console.error('GEMINI_API_KEY is missing in .env');
}

// Initialize AI
const genAI = new GoogleGenerativeAI(GEMINI_API_KEY || '');
const model = genAI.getGenerativeModel({ model: 'gemini-1.5-flash' });

// Initialize Bot
const bot = new Telegraf(TOKEN || '');

// Load Products Catalog
const productsPath = path.resolve('products.json');
let products = [];
try {
  const data = fs.readFileSync(productsPath, 'utf-8');
  products = JSON.parse(data);
} catch (error) {
  console.error('Error loading products.json:', error);
}

// Bot logic
bot.start((ctx) => {
  ctx.reply(`👋 Я твой персональный ИИ-стилист DARKSTEP!\n\nНапиши мне, что ты ищешь или какой образ хочешь подобрать. Например:\n— "Подбери мне летний образ с шортами"\n— "Что у вас есть из обуви на весну?"\n— "С чем лучше сочетать черную куртку?"\n\nЯ проанализирую наш ассортимент и дам рекомендации!`);
});

bot.on('text', async (ctx) => {
  const userMessage = ctx.message.text;

  try {
    // Show typing status
    await ctx.sendChatAction('typing');

    // Sort products by date (newest first) for context
    const sortedProducts = [...products].sort((a, b) => {
      const dateA = new Date(a.addedAt || 0).getTime();
      const dateB = new Date(b.addedAt || 0).getTime();
      return dateB - dateA;
    });

    const currentDate = new Date().toISOString();

    const prompt = `
      Ты — профессиональный ИИ-стилист магазина одежды "DARKSTEP". 
      Твоя задача — помогать клиентам подбирать образы из нашего ассортимента.
      
      Сегодняшняя дата: ${currentDate}
      
      Вот наш список товаров (отсортирован: сначала самые новые):
      ${JSON.stringify(sortedProducts, null, 2)}
      
      Правила:
      1. Отвечай вежливо и профессионально.
      2. Если пользователь ищет новинки или что-то "недавно добавленное", предлагай товары с самыми свежими датами (addedAt).
      3. При обычных запросах старайся в первую очередь упоминать более новые поступления, если они подходят по смыслу.
      4. Если подходящих вещей нет, предложи наиболее близкие варианты или дай общий совет по стилю.
      5. Используй информацию из списка (название, категория, описание, цена).
      
      Запрос пользователя: "${userMessage}"
      
      Ответь на языке пользователя (русский).
    `;

    const result = await model.generateContent(prompt);
    const response = await result.response;
    const text = response.text();

    await ctx.reply(text);
  } catch (error) {
    console.error('Gemini Error:', error);
    // Exact error message from the user's screenshot to show we've handled the "overheating"
    await ctx.reply('⚠️ Извини, мой модный процессор перегрелся. Попробуй позже!');
  }
});

// Launch Bot
if (TOKEN) {
  bot.launch().then(() => {
    console.log('Bot is running...');
  }).catch(err => {
    console.error('Failed to launch bot:', err);
  });
}

// Express Server for health checks and keeping the process alive
const app = express();
app.get('/', (req, res) => {
  res.send('DARKSTEP AI Stylist Bot is active.');
});

app.listen(PORT, '0.0.0.0', () => {
  console.log(`Health check server listening on port ${PORT}`);
});

// Enable graceful stop
process.once('SIGINT', () => bot.stop('SIGINT'));
process.once('SIGTERM', () => bot.stop('SIGTERM'));
